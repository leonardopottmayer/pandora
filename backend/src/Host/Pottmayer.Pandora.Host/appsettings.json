{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": []
  },
  "Notifications": {
    "ActivationUrlTemplate": "https://localhost/activate?token={token}",
    "DispatchIntervalSeconds": 15,
    "DispatchBatchSize": 20
  },
  "Communication": {
    "Email": {
      "Provider": "mailkit",
      "Smtp": {
        "Host": "localhost",
        "Port": 1025,
        "UseStartTls": false,
        "Username": "",
        "Password": "",
        "FromAddress": "no-reply@pandora.local",
        "FromName": "Pandora"
      }
    }
  },
  "Tars": {
    "Data": {
      "Connections": {
        "identity": {
          "ConnectionString": "Host=localhost;Port=5433;Database=pottmayer_pandora_local;Username=postgres;Password=postgres;Include Error Detail=true"
        },
        "notifications": {
          "ConnectionString": "Host=localhost;Port=5433;Database=pottmayer_pandora_local;Username=postgres;Password=postgres;Include Error Detail=true"
        }
      }
    },
    "Security": {
      "Identity": {
        "Jwt": {
          "Issuer": "pandora",
          "Audience": "pandora",
          "SigningKey": "CHANGE_ME_IN_PRODUCTION_USE_A_LONG_RANDOM_SECRET_KEY_32CHARS",
          "AccessTokenLifetime": "00:15:00"
        },
        "RefreshToken": {
          "Lifetime": "1.00:00:00",
          "RotationEnabled": true,
          "ReuseDetectionEnabled": true
        }
      }
    }
  }
}

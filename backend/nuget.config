<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Private feed hosting the Pottmayer.Tars.* packages. Credentials are
         injected at build time (see backend/Dockerfile) or come from the
         developer's global NuGet.Config on the host machine. -->
    <add key="github" value="https://nuget.pkg.github.com/leonardopottmayer/index.json" />
  </packageSources>
</configuration>

# Template for a per-environment env file. Copy to .env.<environment>
# (e.g. .env.prod, .env.staging), fill with real values, and keep a copy in
# Bitwarden. docker compose loads it via --env-file. See docs/deployment.md.

# --- Environment identity ---
# Isolates containers/network/volumes between environments. Use a distinct
# value per environment: pandora-prod, pandora-staging, ...
COMPOSE_PROJECT_NAME=pandora-prod
# ASP.NET Core environment name (Production for every real deploy).
ASPNETCORE_ENVIRONMENT=Production
# Compose profiles to activate. Set to "mailhog" to run the email catcher
# (staging). Leave empty in prod (uses a real SMTP provider instead).
COMPOSE_PROFILES=

# --- Postgres ---
POSTGRES_USER=pandora
POSTGRES_PASSWORD=change_me
POSTGRES_DB=pottmayer_pandora
# Localhost-only port for host tools (migris). Unique per environment so both
# stacks can run at once: prod=5432, staging=5433, ... Not exposed to the LAN.
POSTGRES_PORT=5432

# --- Backend secrets (generate strong random values) ---
# At least 32 chars.
JWT_SIGNING_KEY=CHANGE_ME_LONG_RANDOM_AT_LEAST_32_CHARS
# Base64 of 32 random bytes.
MFA_ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTES

# --- Published images (GHCR) ---
# Same images serve every environment; only this file differs.
# prod -> pin a version tag; staging -> :latest.
BACKEND_IMAGE=ghcr.io/leonardopottmayer/pandora-backend:latest
FRONTEND_IMAGE=ghcr.io/leonardopottmayer/pandora-frontend:latest

# --- Email ---
# Staging: point at the bundled Mailhog (needs COMPOSE_PROFILES=mailhog above).
# Prod: set to a real SMTP provider's host/port instead.
SMTP_HOST=mailhog
SMTP_PORT=1025
# Mailhog web UI port on the host (only used when the mailhog profile is on).
MAILHOG_UI_PORT=8732

# --- Host port exposed for the frontend (nginx) ---
# The ONLY host port this stack uses (postgres/backend stay internal to the
# Docker network). Reserve one per environment: prod=8730, staging=8731, ...
HTTP_PORT=8730

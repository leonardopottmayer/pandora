# Shared tier Postgres. Copy to .env.staging / .env.prod and fill.
# Usage: docker compose --env-file .env.staging up -d

# Compose project name (isolates the container/volume per tier).
DB_PROJECT_NAME=staging-db
# Hostname apps use to reach this DB on the tier network.
DB_HOST=staging-db
# Shared Docker network for this tier (create once: docker network create staging).
TIER_NETWORK=staging

# Superuser (admin only — used to provision per-app databases/roles).
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERPASSWORD=change_me_super

# Localhost-only port for host tools (migris/psql). staging=5433, prod=5432.
DB_PORT=5433
